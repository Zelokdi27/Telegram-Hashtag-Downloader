# API keys · Ключи API — https://my.telegram.org/apps
API_ID=12345678
API_HASH=your_api_hash_here

# Hashtag (no #) · Хештег без #
HASHTAG=mytag

# Download folder · Папка загрузок
DOWNLOAD_DIR=data/downloads

# Posts per API request (max 100) · Постов за запрос API (макс. 100)
PAGE_LIMIT=50

# Max media per run (0 = unlimited) · Макс. медиа за запуск (0 = без лимита)
MAX_POSTS=0

# Remember search form on exit · Запоминать форму поиска при выходе
REMEMBER_LAST_SEARCH=false

# Step-by-step preview · Пошаговый предпросмотр
SEQUENTIAL_PREVIEW=false
PREVIEW_BATCH_SIZE=200

# Date filter YYYY-MM-DD · Фильтр даты ГГГГ-ММ-ДД
DATE_FROM=
DATE_TO=

# Channel filter (@name or t.me link) · Фильтр канала
CHANNEL_FILTER=

# Telethon session name · Имя сессии
SESSION_NAME=hashtag_session

# Proxy · Прокси
PROXY_ENABLED=false
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=1080

# Media types · Типы медиа
MEDIA_PHOTO=true
MEDIA_VIDEO=true
MEDIA_ANIMATION=true
MEDIA_AUDIO=true
MEDIA_DOCUMENT=true

# Extra hashtags/channels, exclusions · Доп. хештеги/каналы, исключения
EXTRA_HASHTAGS=
EXCLUDE_HASHTAGS=
EXTRA_CHANNELS=

# Filename options · Имена файлов
FOLDER_BY_DATE=false
CAPTION_IN_FILENAME=false
CAPTION_MAX_LEN=40

# Hash dedup · Дедуп по хешу
DEDUP_BY_HASH=true

# Download retries 0–10 · Повторы скачивания
DOWNLOAD_RETRIES=3

# Parallel workers · Параллельные потоки
PREVIEW_PARALLEL_WORKERS=3
DOWNLOAD_PARALLEL_WORKERS=1

# Dark theme · Тёмная тема
DARK_THEME=false

# Windows notifications · Уведомления Windows
WIN_NOTIFY_ENABLED=true
WIN_NOTIFY_SUCCESS=true
WIN_NOTIFY_ERRORS=true

# Setup wizard done · Мастер настройки завершён
SETUP_WIZARD_COMPLETED=false

# UI language: system, ru, en · Язык интерфейса
UI_LANGUAGE=system
